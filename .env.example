# Prompt2PRD 环境变量配置示例
# 复制此文件为 .env 并填入你自己的值。.env 文件不会被提交到版本控制。
#
# 所有变量均有合理默认值，仅在你需要自定义时才需设置。

# ---- 模型连接 ----
# 启用服务端系统 Key（需要 PROMPT2PRD_MODEL_SYSTEM_API_KEY 同时设置）
PROMPT2PRD_MODEL_SYSTEM_KEY_ENABLED=false
# 服务端系统 API Key（部署者提供，不暴露给前端）
PROMPT2PRD_MODEL_SYSTEM_API_KEY=

# ---- 私网模型地址白名单 ----
# 逗号分隔的私有网络主机名或 IP 地址列表，仅在模型服务部署在内网时需要
PROMPT2PRD_MODEL_PRIVATE_HOST_ALLOWLIST=

# ---- 限额配置 ----
# 每 IP 每日系统 Key 分析操作次数（默认 3）
PROMPT2PRD_QUOTA_ANALYSIS_DAILY_LIMIT=3
# 每 IP 每日系统 Key 完整 PRD 生成次数（默认 1）
PROMPT2PRD_QUOTA_FULL_PRD_DAILY_LIMIT=1
# 全局每日上游模型调用次数上限（默认 100）
PROMPT2PRD_QUOTA_GLOBAL_DAILY_CALL_LIMIT=100
# 每 IP 每分钟最大请求数（默认 30）
PROMPT2PRD_QUOTA_REQUESTS_PER_MINUTE=30
# 限流追踪最大条目数（默认 10000）
PROMPT2PRD_QUOTA_MAX_TRACKED_ENTRIES=10000
# IP 摘要加盐值（留空则自动生成随机 UUID）
PROMPT2PRD_QUOTA_IP_DIGEST_SALT=

# ---- 生成超时与重试 ----
# 模型连接超时秒数（默认 30）
PROMPT2PRD_GENERATION_CONNECTION_TIMEOUT_SECONDS=30
# 单次生成任务总超时秒数（默认 300，即 5 分钟）
PROMPT2PRD_GENERATION_TOTAL_TIMEOUT_SECONDS=300
# 可恢复网络错误最大重试次数（默认 3）
PROMPT2PRD_GENERATION_MAX_RETRIES=3
# 重试退避初始毫秒数（默认 800）
PROMPT2PRD_GENERATION_RETRY_BACKOFF_MS=800
# 流式空闲心跳间隔秒数（默认 5）
PROMPT2PRD_GENERATION_HEARTBEAT_INTERVAL_SECONDS=5
